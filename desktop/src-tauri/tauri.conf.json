{
  "productName": "SuperDev",
  "version": "0.1.0",
  "identifier": "dev.superdev.app",
  "build": {
    "beforeDevCommand": "bash scripts/build-agent.sh && pnpm dev",
    "beforeBuildCommand": "bash scripts/build-agent.sh && pnpm build",
    "devUrl": "http://localhost:6688",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SuperDev",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/superdev-agent"]
  }
}
